# Environment configuration
# Copy to .env and fill in your values

# App
APP_NAME=FLOW
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./flow.db
# For PostgreSQL: postgresql://user:pass@localhost:5432/flow

# GPU
CUDA_VISIBLE_DEVICES=0
USE_GPU=true

# Neural Operator
NEURAL_MODEL_DIR=./models
DEFAULT_SOLVER=fea_classic

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
UPLOAD_DIR=./uploads
RESULTS_DIR=./results
MAX_UPLOAD_SIZE_MB=100
